# Copie ce fichier en .env (non versionné) : cp .env.example .env

# --- Qdrant (base vectorielle, lancée via `docker compose up -d`) ---
QDRANT_HOST=localhost
QDRANT_PORT=6333

# --- Fournisseur LLM : ollama (local, défaut) | nebius | groq ---
LLM_PROVIDER=ollama

# --- Clés API (uniquement si provider cloud ; laisser vide pour ollama) ---
# NEBIUS_API_KEY=
# GROQ_API_KEY=
